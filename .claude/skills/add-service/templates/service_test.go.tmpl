func TestRun_HappyPath(t *testing.T) {
	client := newTestClient(t)
	httpmock.RegisterResponder(http.MethodGet,
		"=~^https://api.example.com/v1/lookup", // regex match; baseURL stub
		httpmock.NewStringResponder(http.StatusOK, `{"items":["foo","bar"]}`),
	)

	svc := <name>.NewService(client, testutil.NopLogger())
	raw, err := svc.Run(context.Background(), "example.com")
	require.NoError(t, err)

	result, ok := raw.(*<name>.Result)
	require.True(t, ok, "expected *<name>.Result")
	assert.Equal(t, "example.com", result.Input)
	// TODO: assert the populated fields.
}

func TestRun_Empty(t *testing.T) {
	client := newTestClient(t)
	httpmock.RegisterResponder(http.MethodGet,
		"=~^https://api.example.com/v1/lookup",
		httpmock.NewStringResponder(http.StatusNotFound, ``),
	)

	svc := <name>.NewService(client, testutil.NopLogger())
	raw, err := svc.Run(context.Background(), "example.com")
	require.NoError(t, err, "404 must be a non-error empty result, not an error")

	result := raw.(*<name>.Result)
	assert.True(t, result.IsEmpty())
}

func TestRun_TransportError(t *testing.T) {
	client := newTestClient(t)
	httpmock.RegisterResponder(http.MethodGet,
		"=~^https://api.example.com/v1/lookup",
		httpmock.NewErrorResponder(errors.New("simulated network failure")),
	)

	svc := <name>.NewService(client, testutil.NopLogger())
	_, err := svc.Run(context.Background(), "example.com")
	require.Error(t, err)
	assert.ErrorIs(t, err, services.ErrRequestFailed)
}

