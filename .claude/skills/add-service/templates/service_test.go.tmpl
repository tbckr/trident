// newTestClient wires an httpmock-backed *req.Client. Call .GetClient() to
// reach the inner *http.Client — that is the surface httpmock can intercept.
func newTestClient(t *testing.T) *req.Client {
	t.Helper()
	client := req.NewClient()
	httpmock.ActivateNonDefault(client.GetClient())
	t.Cleanup(httpmock.DeactivateAndReset)
	return client
}

